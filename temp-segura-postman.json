        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"testuser{{$timestamp}}\",\n  \"email\": \"test{{$timestamp}}@example.com\",\n  \"password\": \"Test1234\",\n  \"phone\": \"+541112345678\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/auth/register",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "register"]
            },
            "description": "Registrar nuevo usuario"
          },
          "response": []
        },
        {
