{
  "info": {
    "_postman_id": "fd69e54d-2d2f-4d78-93f8-esp32-simulator",
    "name": "Temp Segura - Simulador ESP32 HTTP/SMS",
    "description": "Coleccion para simular el protocolo ESP32 v2.1 definido en docs/protocolo-comunicacion-esp-v2.1.md. Calcula timestamp y HMAC-SHA256 automaticamente en Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "esp_mac",
      "value": "A1:B2:C3:D4:E5:01",
      "type": "string"
    },
    {
      "key": "esp_secret",
      "value": "local-dev-esp-secret",
      "type": "string"
    },
    {
      "key": "activation_keyword",
      "value": "clavesecreta4321",
      "type": "string"
    },
    {
      "key": "device_model",
      "value": "ESP32-GSM-V3",
      "type": "string"
    },
    {
      "key": "firmware_version",
      "value": "1.0.2",
      "type": "string"
    },
    {
      "key": "protocol_version",
      "value": "2.1",
      "type": "string"
    },
    {
      "key": "sim_imei",
      "value": "354829071122334",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function normalizeMac(mac) {",
          "  const compact = String(mac || '').replace(/[^a-fA-F0-9]/g, '').toUpperCase();",
          "  return compact.match(/.{1,2}/g).join(':');",
          "}",
          "",
          "function normalizeForJson(value) {",
          "  if (Array.isArray(value)) return value.map(normalizeForJson);",
          "  if (value && typeof value === 'object') {",
          "    return Object.keys(value).sort().reduce((acc, key) => {",
          "      acc[key] = normalizeForJson(value[key]);",
          "      return acc;",
          "    }, {});",
          "  }",
          "  return value;",
          "}",
          "",
          "function signedPayload(payload) {",
          "  const mac = normalizeMac(payload.mac);",
          "  payload.mac = mac;",
          "  const clone = JSON.parse(JSON.stringify(payload));",
          "  delete clone.mac;",
          "  delete clone.timestamp;",
          "  delete clone.signature;",
          "  const jsonData = JSON.stringify(normalizeForJson(clone));",
          "  const secret = pm.collectionVariables.get('esp_secret') || 'local-dev-esp-secret';",
          "  payload.signature = CryptoJS.HmacSHA256(mac + payload.timestamp + jsonData, secret).toString(CryptoJS.enc.Hex);",
          "  return payload;",
          "}",
          "",
          "function nextPacketId(prefix) {",
          "  return prefix + '-' + Date.now() + '-' + Math.floor(Math.random() * 10000);",
          "}",
          "",
          "function writeBody(payload) {",
          "  pm.request.body.update(JSON.stringify(payload, null, 2));",
          "}"
        ]
      }
    }
  ],
