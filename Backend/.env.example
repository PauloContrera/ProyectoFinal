DB_HOST=localhost
DB_NAME=temp_segura
DB_USER=root
DB_PASS=

JWT_SECRET=replace_with_64_or_more_random_hex_chars
JWT_EXPIRATION=3600
JWT_ISSUER=temp-segura

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=replace@example.com
MAIL_PASS=replace_with_app_password
MAIL_FROM_EMAIL=replace@example.com

APP_URL=http://localhost:5173
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_JSON_BODY_BYTES=1048576

ACCOUNT_LOCK_ATTEMPTS=5
IP_BLOCK_ATTEMPTS=10
IP_BLOCK_DURATION=60

ESP_DEFAULT_SECRET=replace_with_device_bootstrap_secret
ESP_ACTIVATION_KEYWORD=replace_with_activation_keyword
ESP_REQUIRE_ACTIVATION_KEY=true
ESP_TIMESTAMP_TOLERANCE=900
ESP_MAX_BATCH_SIZE=120
ESP_RETRY_BASE_SECONDS=30
ESP_RECORD_MAX_AGE_SECONDS=604800
ESP_RECORD_FUTURE_TOLERANCE_SECONDS=900
